# Optional local defaults for repeat demos.
# You do NOT need this file to run the proof of concept.
# If present, these values simply prefill the in-app setup flow.

# CTM API credentials (Settings > API Keys in CTM)
CTM_API_KEY=your_api_key_here
CTM_API_SECRET=your_api_secret_here

# CTM account ID (found in the CTM app URL)
CTM_ACCOUNT_ID=11774

# Optional: auto-fill the setup form with a specific agent
CTM_USER_EMAIL=agent@example.com
CTM_USER_FIRST=Alex
CTM_USER_LAST=Agent

# Optional: enable the Account Assist chat widget
CTM_CHAT_TOKEN=

# Optional: left-rail ops feed sources
OPS_WEATHER_CITY=New York, NY
OPS_NEWS_FEED_URL=https://feeds.npr.org/1001/rss.xml

# Optional: override the external account assessment tooling paths
CTM_ASSESSMENT_SCRIPT=~/Scripts/ctm-account-assessment/src/ctm_account_asses.py
CTM_ASSESSMENT_PYTHON=~/Scripts/ctm-account-assessment/venv/bin/python

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-secret
